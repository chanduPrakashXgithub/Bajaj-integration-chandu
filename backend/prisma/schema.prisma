generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  name               String
  email              String          @unique
  password           String
  role               RoleId
  position           String
  phone              String          @default("Pending")
  shift              String          @default("09:00 - 18:00")
  joinDate           DateTime        @default(now())
  status             String          @default("Present")
  rating             Float           @default(4.0)
  attendancePct      Float           @default(100.0)
  tasksClosed        Int             @default(0)
  proofRate          Float           @default(100.0)
  escalations        Int             @default(0)
  managerId          String?
  salary             Float           @default(0.0)
  lastCheckIn        String          @default("Not marked")
  skills             Json            @default("[]")
  emergencyContact   String          @default("Pending")
  documents          Json            @default("[]")
  deviceId           String          @default("")
  expoPushToken      String?
  branchId           String?
  branchScope        String[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  requestedApprovals Approval[]      @relation("RequestedApprovals")
  attendanceLogs     AttendanceLog[]
  reportedComplaints Complaint[]     @relation("ReportedComplaints")
  resolvedComplaints Complaint[]     @relation("ResolvedComplaints")
  createdChecks      Check[]         @relation("CreatedChecks")
  assignedChecks     Check[]         @relation("AssignedChecks")
  completedChecks    Check[]         @relation("CompletedChecks")
  branch             Branch?         @relation("UserBranch", fields: [branchId], references: [id])
  manager            User?           @relation("UserToManager", fields: [managerId], references: [id])
  subordinates       User[]          @relation("UserToManager")
  scheduledVisits    Visit[]         @relation("ManagerVisits")

  @@index([role])
}

model Branch {
  id               String         @id @default(uuid())
  code             String         @unique
  name             String         @unique
  city             String
  address          String
  phone            String         @default("Pending")
  email            String         @default("Pending")
  geoRadius        Float          @default(180.0)
  shiftWindow      String         @default("07:00 - 15:00")
  health           Float          @default(100.0)
  performance      Float          @default(100.0)
  todayAttendance  Float          @default(100.0)
  staffCount       Int            @default(0)
  workerCount      Int            @default(0)
  monthlyBudget    Float          @default(50000.0)
  usedBudget       Float          @default(0.0)
  openIssues       Int            @default(0)
  criticalAlerts   Int            @default(0)
  applianceRisk    Int            @default(0)
  auditScore       Float          @default(100.0)
  lastVisit        String         @default("Not visited")
  nextVisit        String         @default("Pending")
  revenueIndex     Float          @default(1.0)
  customerFootfall Int            @default(0)
  sla              Float          @default(100.0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  district         String         @default("Unknown")
  appliances       Appliance[]
  approvals        Approval[]
  complaints       Complaint[]
  notifications    Notification[]
  checks           Check[]
  users            User[]         @relation("UserBranch")
  visits           Visit[]

  @@index([name])
}

model Appliance {
  id             String          @id @default(uuid())
  branchId       String
  name           String
  category       String
  zone           String          @default("Branch premises")
  brand          String
  model          String          @default("Pending")
  serial         String          @unique
  imageUrl       String          @default("")
  healthScore    Int             @default(100)
  status         ApplianceStatus @default(Operational)
  purchaseDate   DateTime?
  lastService    DateTime?
  nextService    DateTime?
  warranty       String          @default("Pending")
  amcVendor      String          @default("To be assigned")
  vendorEmail    String          @default("")
  purchaseCost   Float           @default(0.0)
  approvalStatus String          @default("Approved")
  pendingParts   String          @default("None")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  complaints     Complaint[]
  checks         Check[]

  @@index([branchId])
  @@index([category])
}

model Check {
  id             String     @id @default(uuid())
  title          String
  branchId       String
  audience       RoleId     @default(lc)
  schedule       String     @default("Daily")
  priority       Priority   @default(High)
  zone           String     @default("Branch premises")
  deadline       DateTime
  assignedToId   String?
  assignedById   String
  status         TaskStatus @default(Pending)
  checklistDone  Int        @default(0)
  checklistTotal Int        @default(1)
  proofRequired  Boolean    @default(false)
  proofLabel     String     @default("Photo proof")
  proofUrl       String?
  completedById  String?
  completedAt    DateTime?
  notes          String
  escalation     String     @default("None")
  redoReason     String?
  applianceId    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  appliance      Appliance? @relation(fields: [applianceId], references: [id])
  assignedBy     User       @relation("CreatedChecks", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedTo     User?      @relation("AssignedChecks", fields: [assignedToId], references: [id])
  branch         Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  completedBy    User?      @relation("CompletedChecks", fields: [completedById], references: [id])

  @@index([branchId])
  @@index([assignedToId])
  @@index([status])
  @@map("Task")
}

model AttendanceLog {
  id              String               @id @default(uuid())
  userId          String
  date            String
  status          AttStatus            @default(Present)
  checkIn         String
  checkOut        String?
  location        String               @default("Inside geo fence")
  proof           String               @default("Geo + selfie verified")
  deviation       String               @default("No")
  latitude        Float?
  longitude       Float?
  isBranchOpening Boolean              @default(false)
  remarks         String?
  photos          Json                 @default("[]")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyTasks     WeeklyTaskPlanItem[]

  @@unique([userId, date])
  @@index([userId])
}

model WeeklyTaskPlanItem {
  id             String        @id @default(uuid())
  attendanceId   String
  description    String
  estimatedHours Float         @default(0.0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  attendance     AttendanceLog @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Complaint {
  id               String          @id @default(uuid())
  complaintId      String          @unique
  branchId         String
  assetId          String?
  vendorId         String?
  vendorEmail      String?
  priority         Priority        @default(Medium)
  description      String
  attachmentUrls   String[]        @default([])
  status           ComplaintStatus @default(OPEN)
  raisedById       String
  raisedByName     String?
  raisedByRole     String?
  resolvedById     String?
  resolvedByName   String?
  resolutionNotes  String?
  vendorRemarks    String?
  vendorIssueId    String?
  resolvedAt       DateTime?
  workOrderPdfUrl  String?
  completionPdfUrl String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  asset            Appliance?      @relation(fields: [assetId], references: [id])
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  raisedBy         User            @relation("ReportedComplaints", fields: [raisedById], references: [id], onDelete: Cascade)
  resolvedBy       User?           @relation("ResolvedComplaints", fields: [resolvedById], references: [id])

  @@index([branchId])
  @@index([status])
  @@index([raisedById])
}

model Approval {
  id            String         @id @default(uuid())
  title         String
  kind          String
  branchId      String
  amount        Float
  requestedById String
  status        ApprovalStatus @default(Pending)
  stage         String         @default("Branch Manager")
  priority      Priority       @default(High)
  age           String         @default("Just now")
  note          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation("RequestedApprovals", fields: [requestedById], references: [id], onDelete: Cascade)
}

model Visit {
  id          String      @id @default(uuid())
  branchId    String
  managerId   String
  scheduledAt DateTime
  purpose     String
  agenda      String
  status      VisitStatus @default(Scheduled)
  report      String      @default("Pending")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  manager     User        @relation("ManagerVisits", fields: [managerId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  detail     String
  scope      RoleId[]
  branchId   String
  priority   Priority @default(Medium)
  read       Boolean  @default(false)
  bookmarked Boolean  @default(false)
  time       String   @default("Just now")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

enum RoleId {
  lc
  branchManager
  aa
  am
  rm
}

enum Priority {
  Critical
  High
  Medium
  Low
}

enum TaskStatus {
  Pending
  InProgress
  Completed
  Revoked
}

enum ComplaintStatus {
  OPEN
  VENDOR_PENDING
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  REOPENED
  ACKNOWLEDGED
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
}

enum ApplianceStatus {
  Operational
  AtRisk
  Critical
  Down
}

enum VisitStatus {
  Scheduled
  Escalated
  Completed
  Cancelled
}

enum AttStatus {
  Present
  Late
  Absent
}
